   "metadata": {},
   "source": [
    "# Ridge Regression - From Scratch (NumPy)\n",
    "\n",
    "## What is Ridge Regression?\n",
    "\n",
    "Ridge Regression is a version of linear regression that adds an L2 penalty to control large coefficient values. While Linear Regression only minimizes prediction error, it can become unstable when features are highly correlated. Ridge solves this by shrinking coefficients making the model more stable and reducing overfitting.\n",
    "\n",
    "---\n",
    "\n",
    "## Key Benefits\n",
    "\n",
    "| Benefit | Description |\n",
    "|---------|-------------|\n",
    "| L2 Regularization | Adds an L2 penalty to model weights |\n",
    "| Bias-Variance Tradeoff | Controls how large coefficients can grow |\n",
    "| Multicollinearity | Improves stability when features overlap |\n",
    "| Generalization | Helps the model generalize better on new data |\n",
    "\n",
    "---\n",
    "\n",
    "## Ridge Formula\n",
    "\n",
    "$$\\text{Loss} = \\sum_{i=1}^{n} (y_i - \\hat{y}_i)^2 + \\lambda \\sum_{j=1}^{p} w_j^2$$\n",
    "\n",
    "Where:\n",
    "- $\\lambda$ is the regularization parameter (alpha)\n",
    "- $w_j$ are the model coefficients\n",
    "\n",
    "The closed-form solution for Ridge Regression:\n",
    "\n",
    "$$w = (X^T X + \\lambda I)^{-1} X^T y$$\n",
    "\n",
    "---\n",
    "\n",
    "## One-Line Summary\n",
    "\n",
    "**Ridge Regression adds L2 penalty to linear regression, reducing overfitting by shrinking coefficients and handling multicollinearity.**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import mean_squared_error, r2_score\n",
    "\n",
    "print(\"=\"*50)\n",
    "print(\"RIDGE REGRESSION - FROM SCRATCH\")\n",
    "print(\"=\"*50)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Ridge Regression Class from Scratch"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class RidgeRegression:\n",
    "    \"\"\"\n",
    "    Ridge Regression implementation from scratch using closed-form solution\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, alpha=1.0, fit_intercept=True):\n",
    "        self.alpha = alpha  # Regularization parameter (lambda)\n",
    "        self.fit_intercept = fit_intercept\n",
    "        self.coef_ = None\n",
    "        self.intercept_ = None\n",
    "    \n",
    "    def fit(self, X, y):\n",
    "        \"\"\"\n",
    "        Fit Ridge Regression model using closed-form solution\n",
    "        w = (X^T X + lambda*I)^-1 X^T y\n",
    "        \"\"\"\n",
    "        X = np.array(X)\n",
    "        y = np.array(y)\n",
    "        \n",
    "        if self.fit_intercept:\n",
    "            # Add bias term (column of ones)\n",
    "            X = np.column_stack([np.ones(len(X)), X])\n",
    "        \n",
    "        n_features = X.shape[1]\n",
    "        \n",
    "        # Identity matrix with regularization only for coefficients (not bias)\n",
    "        I = np.eye(n_features)\n",
    "        if self.fit_intercept:\n",
    "            I[0, 0] = 0  # Don't regularize bias term\n",
    "        \n",
    "        # Closed-form solution: (X^T X + alpha*I)^-1 X^T y\n",
    "        XTX = X.T @ X\n",
    "        XTy = X.T @ y\n",
    "        \n",
    "        # Add regularization\n",
    "        XTX_reg = XTX + self.alpha * I\n",
    "        \n",
    "        # Solve for weights\n",
    "        weights = np.linalg.solve(XTX_reg, XTy)\n",
    "        \n",
    "        if self.fit_intercept:\n",
    "            self.intercept_ = weights[0]\n",
    "            self.coef_ = weights[1:]\n",
    "        else:\n",
    "            self.intercept_ = 0\n",
    "            self.coef_ = weights\n",
    "        \n",
    "        return self\n",
    "    \n",
    "    def predict(self, X):\n",
    "        \"\"\"Make predictions\"\"\"\n",
    "        X = np.array(X)\n",
    "        return X @ self.coef_ + self.intercept_\n",
    "    \n",
    "    def score(self, X, y):\n",
    "        \"\"\"Calculate R2 score\"\"\"\n",
    "        y_pred = self.predict(X)\n",
    "        return r2_score(y, y_pred)"
   ]
  },
  {
   "cell_type": "markdown",
   {"metadata": {}, "source": []},
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create synthetic dataset\n",
    "np.random.seed(0)\n",
    "n_samples = 200\n",
    "n_features = 6\n",
    "\n",
    "X = np.random.randn(n_samples, n_features)\n",
    "true_coef = np.array([3.2, -1.5, 0.7, 0, 2.8, -0.5])\n",
    "y = X.dot(true_coef) + np.random.randn(n_samples) * 0.6\n",
    "\n",
    "print(\"Dataset created:\")\n",
    "print(f\"Samples: {n_samples}\")\n",
    "print(f\"Features: {n_features}\")\n",
    "print(f\"True coefficients: {true_coef}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Scale features\n",
    "scaler = StandardScaler()\n",
    "X_scaled = scaler.fit_transform(X)\n",
    "\n",
    "# Split data\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X_scaled, y, test_size=0.25, random_state=42\n",
    ")\n",
    "\n",
    "print(f\"Train size: {len(X_train)}\")\n",
    "print(f\"Test size: {len(X_test)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Train Ridge from scratch\n",
    "ridge_scratch = RidgeRegression(alpha=1.0)\n",
    "ridge_scratch.fit(X_train, y_train)\n",
    "\n",
    "y_pred_scratch = ridge_scratch.predict(X_test)\n",
    "mse_scratch = mean_squared_error(y_test, y_pred_scratch)\n",
    "r2_scratch = r2_score(y_test, y_pred_scratch)\n",
    "\n",
    "print(\"Ridge Regression (From Scratch) Results:\")\n",
    "print(f\"MSE: {mse_scratch:.4f}\")\n",
    "print(f\"R2 Score: {r2_scratch:.4f}\")\n",
    "print(f\"Coefficients: {ridge_scratch.coef_}\")\n",
    "print(f\"Intercept: {ridge_scratch.intercept_:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare with sklearn Ridge\n",
    "from sklearn.linear_model import Ridge\n",
    "\n",
    "ridge_sklearn = Ridge(alpha=1.0)\n",
    "ridge_sklearn.fit(X_train, y_train)\n",
    "y_pred_sklearn = ridge_sklearn.predict(X_test)\n",
    "mse_sklearn = mean_squared_error(y_test, y_pred_sklearn)\n",
    "r2_sklearn = r2_score(y_test, y_pred_sklearn)\n",
    "\n",
    "print(\"\\n\" + \"=\"*50)\n",
    "print(\"Comparison: From Scratch vs Scikit-Learn\")\n",
    "print(\"=\"*50)\n",
    "print(f\"{'Method':<15} {'MSE':<12} {'R2 Score':<12}\")\n",
    "print(\"-\"*50)\n",
    "print(f\"{'From Scratch':<15} {mse_scratch:<12.4f} {r2_scratch:<12.4f}\")\n",
    "print(f\"{'Scikit-Learn':<15} {mse_sklearn:<12.4f} {r2_sklearn:<12.4f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Effect of different alpha values\n",
    "alphas = [0.001, 0.01, 0.1, 1, 10, 100, 500]\n",
    "mse_scores = []\n",
    "coef_norms = []\n",
    "\n",
    "print(\"\\n\" + \"=\"*50)\n",
    "print(\"Effect of Alpha on Ridge Regression\")\n",
    "print(\"=\"*50)\n",
    "\n",
    "for alpha in alphas:\n",
    "    ridge = RidgeRegression(alpha=alpha)\n",
    "    ridge.fit(X_train, y_train)\n",
    "    y_pred = ridge.predict(X_test)\n",
    "    mse = mean_squared_error(y_test, y_pred)\n",
    "    mse_scores.append(mse)\n",
    "    coef_norms.append(np.linalg.norm(ridge.coef_))\n",
    "    print(f\"Alpha = {alpha:6}: MSE = {mse:.4f}, ||Coefficients|| = {coef_norms[-1]:.2f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize effect of alpha\n",
    "plt.figure(figsize=(12, 5))\n",
    "\n",
    "plt.subplot(1, 2, 1)\n",
    "plt.plot(alphas, mse_scores, marker='o', color='blue')\n",
    "plt.xscale('log')\n",
    "plt.xlabel('Alpha (log scale)')\n",
    "plt.ylabel('MSE')\n",
    "plt.title('Effect of Alpha on Test MSE')\n",
    "plt.grid(alpha=0.3)\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "plt.plot(alphas, coef_norms, marker='s', color='red')\n",
    "plt.xscale('log')\n",
    "plt.xlabel('Alpha (log scale)')\n",
    "plt.ylabel('Coefficient Norm')\n",
    "plt.title('Effect of Alpha on Coefficient Magnitude')\n",
    "plt.grid(alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare coefficients for different alphas\n",
    "plt.figure(figsize=(10, 6))\n",
    "\n",
    "for i, alpha in enumerate([0.01, 1, 100]):\n",
    "    ridge = RidgeRegression(alpha=alpha)\n",
    "    ridge.fit(X_train, y_train)\n",
    "    plt.plot(range(n_features), ridge.coef_, marker='o', label=f'Alpha={alpha}')\n",
    "\n",
    "plt.axhline(y=0, color='black', linestyle='--', alpha=0.5)\n",
    "plt.xlabel('Feature Index')\n",
    "plt.ylabel('Coefficient Value')\n",
    "plt.title('Ridge Coefficients for Different Alpha Values')\n",
    "plt.legend()\n",
    "plt.grid(alpha=0.3)\n",
    "plt.show()"
   ]
  },
